<mxfile host="app.diagrams.net" type="device">
  <diagram name="Decision + Learning Loop" id="loop">
    <mxGraphModel dx="1300" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="The Governed Decision + Learning Loop" style="text;html=1;fontSize=20;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="700" height="30" as="geometry"/></mxCell>
        <mxCell id="sub" value="Agents propose · humans decide · every correction becomes a training signal that makes the next decision cheaper" style="text;html=1;fontSize=12;fontColor=#666666;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="46" width="900" height="24" as="geometry"/></mxCell>

        <!-- Top row: the decision path -->
        <mxCell id="intake" value="1 · Intake&#10;ingest → versioned dataset (Iceberg)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="60" y="110" width="200" height="60" as="geometry"/></mxCell>
        <mxCell id="case" value="2 · Case&#10;anchored to a real row + projection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="320" y="110" width="200" height="60" as="geometry"/></mxCell>
        <mxCell id="agent" value="3 · Agent reasons&#10;grounding (RAG) + ai-gateway ladder + tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b9e0b3;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="580" y="110" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="proposal" value="4 · Proposal (inert)&#10;write-intent + rationale + provenance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="860" y="110" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="human" value="5 · Human decides&#10;approve / edit / reject · four-eyes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1140" y="110" width="220" height="60" as="geometry"/></mxCell>

        <!-- Write-back -->
        <mxCell id="writeback" value="6 · Governed write-back&#10;disposition synced to the tenant System of Record (proposal-mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="1140" y="230" width="220" height="60" as="geometry"/></mxCell>

        <!-- Learning branch -->
        <mxCell id="transcript" value="7 · Transcript (M1)&#10;inputs + grounding + proposed action + human decision + CORRECTED output&#10;PII-redacted · consent-gated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="860" y="330" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="sft" value="8 · SFT dataset (M2)&#10;curate → immutable, versioned, per-archetype&#10;edit → gold input→corrected pair" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="580" y="330" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="train" value="9 · Distill / LoRA train (M3)&#10;GPU node pool → candidate adapter → MLflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontStyle=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="300" y="330" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="gpu-note" value="⚠ GPU-gated: compute behind a typed GpuTrainer port; unconfigured → job FAILS honestly (no fake adapter)" style="text;html=1;fontSize=10;fontColor=#d79b00;align=left;" vertex="1" parent="1"><mxGeometry x="290" y="415" width="260" height="40" as="geometry"/></mxCell>
        <mxCell id="evalgate" value="10 · Eval gate + promote (M4)&#10;eval-service suite → admin promotes adapter as the CHEAPEST rung; rollback = demote" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="300" y="480" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="ladder" value="ai-gateway model ladder&#10;new SLM rung = cheaper next decision&#10;(11 · retrain M5 on drift)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b9e0b3;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="580" y="480" width="240" height="80" as="geometry"/></mxCell>

        <!-- Decision-path edges -->
        <mxCell id="l1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1" source="intake" target="case"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1" source="case" target="agent"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="agent" target="proposal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1" source="proposal" target="human"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l5" value="approve" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#b85450;strokeWidth=2;" edge="1" parent="1" source="human" target="writeback"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Learning-branch edges -->
        <mxCell id="l6" value="capture" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1" source="human" target="transcript"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1" source="transcript" target="sft"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1" source="sft" target="train"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1" source="train" target="evalgate"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="evalgate" target="ladder"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- close the loop: ladder feeds the agent -->
        <mxCell id="l11" value="cheaper next decision" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#82b366;strokeWidth=3;dashed=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="ladder" target="agent"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="700" y="450"/></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
