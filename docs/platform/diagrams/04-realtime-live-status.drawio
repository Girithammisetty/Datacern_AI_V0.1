<mxfile host="app.diagrams.net" type="device">
  <diagram name="Realtime Live Status" id="realtime">
    <mxGraphModel dx="1300" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Workflow: Realtime Live Status (no refetch, no detail page open)" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="900" height="28" as="geometry"/></mxCell>

        <!-- Producer -->
        <mxCell id="svc" value="Owning service&#10;(dataset / case / run …)&#10;resource changes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="kafka" value="Kafka envelope&#10;{event_type, payload, resource_urn}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="280" y="120" width="200" height="70" as="geometry"/></mxCell>

        <!-- Hub -->
        <mxCell id="hub" value="realtime-hub" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;verticalAlign=top;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="540" y="100" width="360" height="200" as="geometry"/></mxCell>
        <mxCell id="route" value="route by event_type →&#10;run-status:&lt;urn&gt;  (detail pages)&#10;+ list:&lt;type&gt;  (list pages)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="130" width="320" height="60" as="geometry"/></mxCell>
        <mxCell id="authz" value="per-topic OPA authz&#10;(realtime.run_status.read)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="200" width="150" height="50" as="geometry"/></mxCell>
        <mxCell id="redis" value="Redis pub/sub&#10;+ replay ring (resume)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="725" y="200" width="155" height="50" as="geometry"/></mxCell>

        <!-- UI -->
        <mxCell id="ui" value="ui-web" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;verticalAlign=top;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="960" y="100" width="480" height="200" as="geometry"/></mxCell>
        <mxCell id="ticket" value="useHubTopics → mint single-use ticket → open SSE stream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1"><mxGeometry x="980" y="130" width="440" height="40" as="geometry"/></mxCell>
        <mxCell id="bridge" value="BRIDGE: translate wire frame → patcher contract&#10;{event_type, payload} → {topic:event_type, flat data + id-from-urn}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1"><mxGeometry x="980" y="180" width="440" height="50" as="geometry"/></mxCell>
        <mxCell id="patch" value="datasetPatcher / casePatcher / … → patch TanStack-Query cache row IN PLACE (no refetch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1"><mxGeometry x="980" y="240" width="440" height="45" as="geometry"/></mxCell>

        <!-- Result -->
        <mxCell id="chip" value="Status chip flips ready → processing → ready&#10;live, no refresh, no detail page open" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1080" y="330" width="280" height="50" as="geometry"/></mxCell>

        <!-- Edges -->
        <mxCell id="re1" value="emit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="svc" target="kafka"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re2" value="consume" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1" source="kafka" target="hub"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re3" value="SSE frame&#10;event: &lt;topic&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;" edge="1" parent="1" source="hub" target="ui"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;html=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1" source="patch" target="chip"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="safe" value="Safe by design: patchers only mutate rows ALREADY in the caller's RBAC-scoped cache — no cross-workspace row insertion. (The bridge was dead platform-wide after a topic-grammar change; restoring it re-enabled live status everywhere.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="420" width="1400" height="50" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
